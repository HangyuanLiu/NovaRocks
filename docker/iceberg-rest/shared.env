# Shared Docker fixture defaults for docker/iceberg-rest.
#
# These ports intentionally use the services' conventional local defaults.
# Per-worktree NovaRocks standalone-server ports are allocated separately by
# up.sh, starting from NOVA_ENV_MYSQL_PORT_START.

NOVA_ENV_SHARED_DOCKER=true
NOVA_ENV_SHARED_COMPOSE_PROJECT=nr-iceberg-rest

NOVA_ENV_MINIO_PORT=9000
NOVA_ENV_MINIO_CONSOLE_PORT=9001
NOVA_ENV_REST_PORT=8181
NOVA_ENV_SPARK_UI_PORT=4040

NOVA_ENV_MYSQL_PORT_START=9030
NOVA_ENV_MYSQL_PORT_RANGE=200

NOVA_ENV_SHARED_REST_WAREHOUSE_URI=s3://warehouse/shared/rest
NOVA_ENV_REST_WAREHOUSE_URI=s3://warehouse/shared/rest

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
