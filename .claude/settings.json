{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "docker/iceberg-rest/up.sh --prepare-only && . docker/iceberg-rest/runtime/current/env.sh && printf 'NovaRocks worktree env ready (mysql_port=%s, rest_port=%s)\\n' \"$NOVA_ENV_MYSQL_PORT\" \"$NOVA_ENV_REST_PORT\"",
            "timeout": 120,
            "statusMessage": "Preparing NovaRocks worktree environment..."
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "docker/iceberg-rest/down.sh --runtime-only --purge",
            "timeout": 60,
            "statusMessage": "Cleaning up NovaRocks worktree environment..."
          }
        ]
      }
    ]
  }
}
